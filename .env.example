# Forge Finance — Root Environment Variables
# Copy to .env and fill in values
# Rule C-8: No secrets in code
# Last synced: v5.0.0 Apex prep

# === Frontend (apps/web/.env.local) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SENTRY_DSN=

# === Backend (apps/api/.env) ===
DEBUG=true
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
CORS_ORIGINS=["http://localhost:3000"]

# === Voyage AI (from v0.4.0) ===
# NOTE: env var is VOYAGE_API_KEY (matches settings.voyage_api_key in config.py)
VOYAGE_API_KEY=

# === Plaid (from v0.4.0) ===
# Webhook verification is JWT via plaid-verification header — no shared secret needed.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_WEBHOOK_URL=

# === Stripe (from v5.0.0) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# === Monitoring (from v1.0.0) ===
SENTRY_DSN=

# === FUTURE — not yet wired in code ===
# These are reserved for when @ORACLE moves from hardcoded responses to live LLM calls.
# Do NOT set in production until oracle_agent.py is updated to read them.
# ANTHROPIC_API_KEY=
# LITELLM_MASTER_KEY=
