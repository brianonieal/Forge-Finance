# Forge Finance — Root Environment Variables
# Copy to .env and fill in values
# Rule C-8: No secrets in code

# === Frontend (apps/web/.env.local) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000

# === Backend (apps/api/.env) ===
DEBUG=true
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CORS_ORIGINS=["http://localhost:3000"]

# === AI (from v0.5.0) ===
ANTHROPIC_API_KEY=
VOYAGEAI_API_KEY=
LITELLM_MASTER_KEY=

# === Plaid (from v0.4.0) ===
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_WEBHOOK_URL=
PLAID_WEBHOOK_SECRET=

# === Stripe (from v5.0.0) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === Monitoring (from v1.0.0) ===
SENTRY_DSN=
