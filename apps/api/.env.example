# Forge Finance — Backend Environment Variables
# Copy to .env (apps/api/.env)
# Last synced: v5.0.0 Apex prep
# All variables here are read by app/core/config.py Settings class.

# === Core ===
DEBUG=true
DATABASE_URL=
CORS_ORIGINS=["http://localhost:3000"]

# === Supabase Auth ===
# JWT_SECRET is required for FastAPI JWT verification (app/core/auth.py).
# URL + SERVICE_ROLE_KEY currently unused in Python code but reserved.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# === Plaid ===
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_WEBHOOK_URL=

# === Voyage AI Embeddings ===
VOYAGE_API_KEY=

# === Stripe (from v5.0.0) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# === Sentry ===
SENTRY_DSN=
